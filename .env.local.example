# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_from_the_url

# Fold Money (optional — for auto-importing bank transactions)
FOLD_DEVICE_HASH=generate-a-random-uuid-here
